rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras para Comentários do Gráfico
    match /chart_comments/{commentId} {
      // Qualquer um autenticado pode ler
      allow read: if request.auth != null;
      
      // Qualquer um autenticado pode criar (se o userId bater com o auth.uid)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // APENAS o dono pode apagar
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Ninguém pode editar (opcional, ou permitir apenas dono)
      allow update: if false; 
    }

    // Regras para Usuários (já deve existir algo similar)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Outras coleções...
    match /{document=**} {
      allow read, write: if request.auth != null; // Regra genérica de desenvolvimento (CUIDADO em produção)
    }
  }
}
