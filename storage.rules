rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Regras para Avatares de Usuário
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras para Imagens do Chat
    match /chart_images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regras para Vídeos e Thumbnails (Geralmente Admin)
    match /videos/{videoId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null; // Idealmente restringir a admin
    }
    
    match /videos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /module_thumbnails/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /resources/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regra padrão (cuidado em produção)
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
