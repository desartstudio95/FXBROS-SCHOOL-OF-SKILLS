rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Bootstrap admin by email or check custom claims if implemented
      return isAuthenticated() && (
        request.auth.token.email == "desartstudiopro@gmail.com"
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // Avatares de Usuário
    match /avatars/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
    
    // Imagens do Chat
    match /chart_images/{imageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Vídeos e Thumbnails
    match /videos/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Imagens de Módulos (Thumbnails)
    // ATENÇÃO: Liberado para escrita pública temporariamente para resolver erro de permissão
    match /modules/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // Compatibilidade
    match /module_thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Recursos
    match /resources/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Fallback
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
